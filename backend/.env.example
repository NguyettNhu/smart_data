# Copy this file to `.env` and fill in your own values. `.env` is gitignored.

# ── Email alerts (optional): SMTP send for fall notifications ──────────────
# Use a Gmail App Password (https://myaccount.google.com/apppasswords),
# NOT your normal login password. Leave blank to disable email alerts.
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
EMAIL_RECEIVER=where-to-send-alerts@gmail.com

# ── YOLO model ────────────────────────────────────────────────────────────
# "models/fall_yolo.pt"  → trained 3-class fall detector (committed in repo)
# "yolov8n-pose.pt"      → pose-geometry model (auto-downloaded on first run)
MODEL_PATH=models/fall_yolo.pt
