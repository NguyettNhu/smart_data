node_modules

# Next.js build output
.next/

# Python virtual environment (backend)
backend/.venv/

# Python cache/bytecode
**/__pycache__/
*.py[cod]

# Local env files & secrets (keep .env.example tracked)
**/.env*.local
**/.env

# Model weights: pretrained ones auto-download on first run, but the TRAINED
# fall-detection model IS committed so the repo is self-contained.
*.pt
*.onnx
!backend/models/fall_yolo.pt
backend/*.ts

# Runtime data
backend/stats.db
backend/snapshots/
